{
	"name": "backend",
	"version": "1.0.0",
	"type": "module",
	"description": "This project was bootstrapped with Fastify-CLI.",
	"main": "app.ts",
	"directories": {
		"test": "test"
	},
	"scripts": {
		"test": "npm run build:ts && tsc -p test/tsconfig.json && c8 node --import tsx --test \"test/**/*.ts\"",
		"start": "npm run build:ts && fastify start -l info dist/app.js",
		"build:ts": "tsc && tsc-alias",
		"watch:ts": "concurrently -k -n \"TypeScript,Aliases\" \"tsc -w\" \"tsc-alias -w\"",
		"dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
		"dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/app.js"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@ai-sdk/langchain": "^3.0.22",
		"@fastify/autoload": "^6.0.0",
		"@fastify/sensible": "^6.0.0",
		"@langchain/anthropic": "^1.5.1",
		"@langchain/core": "^1.2.2",
		"@langchain/openai": "^1.5.5",
		"@langchain/textsplitters": "^1.0.1",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"ai": "^7.0.22",
		"cohere-ai": "^8.0.0",
		"documents": "link:@langchain/core/documents",
		"fastify": "^5.0.0",
		"fastify-cli": "^8.0.0",
		"fastify-plugin": "^5.0.0",
		"langchain": "^1.5.3",
		"pg": "^8.22.0",
		"prisma": "^7.8.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^25.0.3",
		"c8": "^11.0.0",
		"concurrently": "^9.0.0",
		"fastify-tsconfig": "^3.0.0",
		"ts-node": "^10.4.0",
		"tsc-alias": "^1.9.0",
		"tsx": "^4.23.0",
		"typescript": "~5.9.2"
	}
}
